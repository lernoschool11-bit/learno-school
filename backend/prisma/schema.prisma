generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  PRINCIPAL
}

model User {
  id          String   @id @default(uuid())
  nationalId  String   @unique
  fullName    String
  username    String   @unique
  dob         String?
  role        Role     @default(STUDENT)
  email       String?  @unique
  password    String
  phoneNumber String?
  school      String?
  schoolId    String?
  linkedSchool School? @relation(fields: [schoolId], references: [id])
  directorate String?
  parentName  String?
  avatarUrl   String?

  grade       String?
  section     String?

  subjects    String[]
  classes     String?

  isActive    Boolean  @default(true)
  aiRequestsCount Int     @default(0)
  lastAiRequest   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts              Post[]
  comments           Comment[]
  likes              Like[]
  assignments        Assignment[]
  submissions        Submission[]
  quizzes            Quiz[]
  messages           Message[]
  followers          Follow[]       @relation("Followers")
  following          Follow[]       @relation("Following")
  notifications      Notification[] @relation("UserNotifications")
  sentNotifications  Notification[] @relation("ActorNotifications")

  // الرسائل الخاصة
  sentConversations     Conversation[]  @relation("SentConversations")
  receivedConversations Conversation[]  @relation("ReceivedConversations")
  directMessages        DirectMessage[]

  studentGrades Grade[] @relation("StudentGrades")
  teacherGrades Grade[] @relation("TeacherGrades")
}

model School {
  id                String   @id @default(uuid())
  name              String   @unique
  adminEmail        String   @unique
  adminPassword     String // Should be hashed, but used for initial setup
  isPasswordChanged Boolean  @default(false)
  teacherSecretCode String   @default("teacher123")
  logoUrl           String?
  
  users             User[]
  posts             Post[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum PostType {
  TEXT
  IMAGE
  STORY
  VIDEO
  DOCUMENT
}

model Post {
  id        String   @id @default(uuid())
  title     String?
  content   String
  mediaUrl  String?
  type      PostType @default(TEXT)

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  Comment[]
  likes     Like[]
}


model Like {
  id        String   @id @default(uuid())

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}

model Follow {
  id          String   @id @default(uuid())

  followerId  String
  follower    User     @relation("Following", fields: [followerId], references: [id])

  followingId String
  following   User     @relation("Followers", fields: [followingId], references: [id])

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  message   String
  isRead    Boolean  @default(false)
  postId    String?

  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id])

  actorId   String
  actor     User     @relation("ActorNotifications", fields: [actorId], references: [id])

  createdAt DateTime @default(now())
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String
  dueDate     DateTime

  teacherId   String
  teacher     User     @relation(fields: [teacherId], references: [id])

  submissions Submission[]
  createdAt   DateTime @default(now())
}

model Submission {
  id           String     @id @default(uuid())
  content      String

  studentId    String
  student      User       @relation(fields: [studentId], references: [id])

  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])

  grade        Float?
  feedback     String?
  submittedAt  DateTime   @default(now())
}

model Quiz {
  id        String     @id @default(uuid())
  title     String

  teacherId String
  teacher   User       @relation(fields: [teacherId], references: [id])

  questions Question[]
  createdAt DateTime   @default(now())
}

model Question {
  id            String   @id @default(uuid())
  text          String
  options       String[]
  correctAnswer String

  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  roomId    String
  content   String
  type      String   @default("text")

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ════════ الرسائل الخاصة ════════

enum ConversationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Conversation {
  id         String             @id @default(uuid())
  status     ConversationStatus @default(PENDING)

  senderId   String
  sender     User               @relation("SentConversations", fields: [senderId], references: [id])

  receiverId String
  receiver   User               @relation("ReceivedConversations", fields: [receiverId], references: [id])

  messages   DirectMessage[]

  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([senderId, receiverId])
}

model DirectMessage {
  id             String       @id @default(uuid())
  content        String

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])

  createdAt      DateTime     @default(now())
}

model Grade {
  id        Int      @id @default(autoincrement())
  studentId String
  teacherId String
  subject   String
  title     String   // مثلاً: "اختبار الفصل الأول" أو "واجب الرياضيات"
  score     Float    // العلامة اللي حصل عليها
  maxScore  Float    // العلامة الكاملة (مثلاً 100)
  createdAt DateTime @default(now())

  student   User @relation("StudentGrades", fields: [studentId], references: [id])
  teacher   User @relation("TeacherGrades", fields: [teacherId], references: [id])
}
